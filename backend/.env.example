# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/localkart
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/localkart

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# ─── Email (Nodemailer) ──────────────────────────────────
# Use Gmail App Password (2FA must be ON → Security → App Passwords)
# Or use Mailtrap for development: https://mailtrap.io
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=LocalKart <your_email@gmail.com>

# ─── Razorpay (test keys) ────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
